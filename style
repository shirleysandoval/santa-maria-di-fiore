/* RESET GENERAL */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* BODY */
body {
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
    line-height: 1.6;
    color: #333;
}

/* NAVBAR */
header {
    background-color: #2c3e50;
    padding: 15px;
    position: sticky;
    top: 0;
    z-index: 1000;
}

/* MENÚ */
nav ul {
    list-style: none;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
}

nav ul li {
    margin: 0 15px;
}

nav ul li a {
    color: white;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
}

nav ul li a:hover {
    color: #f39c12;
}

/* TITULOS */
h1 {
    font-size: 2.5rem;
    text-align: center;
    margin: 30px 0;
    color: #2c3e50;
}

h2 {
    color: #2c3e50;
    margin-bottom: 15px;
}

/* HERO (INDEX) */
.hero {
    text-align: center;
    padding: 40px 20px;
}

.hero p {
    max-width: 800px;
    margin: 0 auto 20px auto;
    font-size: 1.1rem;
}

/* IMAGEN PRINCIPAL */
.hero img {
    width: 80%;
    max-width: 800px;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    margin-top: 20px;
}

/* SECCIONES */
section {
    background: white;
    margin: 30px auto;
    width: 85%;
    max-width: 1000px;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* TEXTO */
p {
    margin-bottom: 15px;
}

/* LISTAS */
ul {
    margin-left: 20px;
    margin-top: 10px;
}

/* BLOQUES DE CÓDIGO (SPARQL) */
pre {
    background-color: #1e1e1e;
    color: #f1f1f1;
    padding: 15px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 15px 0;
}

/* FOOTER */
footer {
    text-align: center;
    background: #2c3e50;
    color: white;
    padding: 20px;
    margin-top: 40px;
}

/* SCROLL SUAVE */
html {
    scroll-behavior: smooth;
}
/* JUSTIFICAR TODO EL TEXTO DE TODAS LAS PÁGINAS */
p {
    text-align: justify;
}
